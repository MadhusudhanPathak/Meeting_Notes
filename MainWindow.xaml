<Window x:Class="MeetingNotesMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MeetingNotesMaker"
        xmlns:converters="clr-namespace:MeetingNotesMaker.Presentation.Converters"
        mc:Ignorable="d"
        Title="Meeting Notes Maker" Height="700" Width="900"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Input Section -->
        <GroupBox Grid.Row="0" Header="Input" Margin="0,0,0,15">
            <StackPanel>
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" Text="{Binding SelectedAudioFile, Mode=OneWay}"
                             IsReadOnly="True" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Select Audio File"
                            Command="{Binding SelectAudioFileCommand}"
                            Padding="15,5" MinWidth="120"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- Configuration Section -->
        <GroupBox Grid.Row="1" Header="Configuration" Margin="0,0,0,15">
            <StackPanel Margin="10">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Ollama Model:" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableModels}"
                              SelectedItem="{Binding SelectedModel}"
                              HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Whisper Model:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding SelectedWhisperModelPath, Mode=OneWay}"
                             IsReadOnly="True" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="Browse..."
                            Command="{Binding SelectWhisperModelCommand}"
                            Padding="10,2" MinWidth="60"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="System Prompt:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding SelectedSystemPromptPath, Mode=OneWay}"
                             IsReadOnly="True" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="Browse..."
                            Command="{Binding SelectSystemPromptCommand}"
                            Padding="10,2" MinWidth="60"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- Processing Section -->
        <GroupBox Grid.Row="2" Header="Processing" Margin="0,0,0,15">
            <StackPanel Margin="10">
                <Button Content="Process Meeting"
                        Command="{Binding ProcessMeetingCommand}"
                        Padding="20,10" FontSize="14" FontWeight="Medium"
                        Foreground="White"
                        Margin="0,0,0,10" Height="40">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Background" Value="LightGray"/>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="True">
                                    <Setter Property="Background" Value="#4CAF50"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="20"
                             Margin="0,0,0,5"/>
                <TextBlock Text="{Binding ProgressText}" HorizontalAlignment="Center"
                           FontStyle="Italic"/>
            </StackPanel>
        </GroupBox>

        <!-- Output Section -->
        <GroupBox Grid.Row="3" Header="Output" Margin="0,0,0,15">
            <StackPanel Margin="10" Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Transcripts and notes will be saved to the Output folder"
                           FontStyle="Italic" VerticalAlignment="Center"/>
            </StackPanel>
        </GroupBox>

        <!-- Preview Section -->
        <GroupBox Grid.Row="4" Header="Preview" Margin="0,0,0,15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding TranscriptPreview}" TextWrapping="Wrap"
                           Padding="10" MaxHeight="200"/>
            </ScrollViewer>
        </GroupBox>
        
        <!-- Status Bar Moved to Bottom -->
        <Border Grid.Row="5" Background="#f0f0f0" Padding="10" CornerRadius="5" Margin="0,0,0,15">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="100">
                <TextBlock Name="StatusTextBlock" Text="{Binding StatusMessage}" FontWeight="Medium" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <StatusBar Grid.Row="6">
            <StatusBarItem>
                <TextBlock Text="Meeting Notes Maker v1.0" FontStyle="Italic"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>